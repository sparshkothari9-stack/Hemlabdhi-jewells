# Server
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=change-this-to-a-random-string-at-least-32-characters-long

# CORS (comma-separated origins for production)
CORS_ORIGINS=

# Admin credentials (for seed script)
ADMIN_EMAIL=sparshkothari9@gmail.com
ADMIN_PASSWORD=change-this-admin-password
CLIENT_PASSWORD=change-this-client-password

# OTP delivery
# Leave OTP_PROVIDER empty for local demo OTP. Use msg91, twilio, or webhook for real deployed OTP.
SHOW_DEMO_OTP=false
OTP_PROVIDER=

# MSG91
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_OTP_VAR=var1

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Generic webhook fallback
OTP_WEBHOOK_URL=
OTP_WEBHOOK_SECRET=
